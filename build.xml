<?xml version="1.0" encoding="UTF-8"?>
<project name="SistemaNutricionistasPI" default="run" basedir=".">
    <property name="src.dir" value="src"/>
    <property name="build.dir" value="build/classes"/>
    <property name="main.class" value="sistemanutricionistaspi.Principal"/>

    <target name="clean">
        <delete dir="build"/>
        <delete dir="dist"/>
    </target>

    <target name="compile">
        <mkdir dir="${build.dir}"/>
        <javac srcdir="${src.dir}" destdir="${build.dir}" includeantruntime="false" source="1.8" target="1.8" encoding="UTF-8"/>
    </target>

    <target name="run" depends="compile">
        <java classname="${main.class}" fork="true">
            <classpath path="${build.dir}"/>
        </java>
    </target>

    <target name="jar" depends="compile">
        <mkdir dir="dist"/>
        <jar destfile="dist/SistemaNutricionistasPI.jar" basedir="${build.dir}">
            <manifest>
                <attribute name="Main-Class" value="${main.class}"/>
            </manifest>
        </jar>
    </target>
</project>
